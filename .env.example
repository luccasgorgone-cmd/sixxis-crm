# Banco de dados PostgreSQL (Prisma)
# Em dev local com Docker use a porta 5433 (ver README/instrucoes)
DATABASE_URL="postgresql://postgres:dev@localhost:5433/sixxiscrm"

# Redis (fila BullMQ). maxRetriesPerRequest e tratado no codigo.
REDIS_URL="redis://localhost:6379"

# Evolution API (recepcao de mensagens do WhatsApp)
EVOLUTION_BASE_URL="https://sua-evolution.exemplo.com"
EVOLUTION_API_KEY="troque-esta-chave"
EVOLUTION_INSTANCE="sixxis-wa1"

# Segredo compartilhado para validar o webhook da Evolution
WEBHOOK_SECRET="troque-este-segredo"

# Ponte com a loja (API interna). A chave NUNCA vai pro browser (so no proxy).
STORE_API_URL="https://sua-loja.exemplo.com"
STORE_INTERNAL_KEY="mesma-chave-do-STORE_INTERNAL_KEY-da-loja"

# Autenticacao (NextAuth v5). Gere o secret com: openssl rand -base64 32
NEXTAUTH_SECRET="troque-este-secret-nextauth"

# Admin semeado no boot (idempotente). Use no primeiro login.
ADMIN_EMAIL="admin@sixxis.com"
ADMIN_SENHA="troque-esta-senha-admin"

# Vendedor de teste (opcional, para validar papeis). Semeado no boot se ambos
# existirem e ainda nao houver Agente com esse email.
VENDEDOR_EMAIL="vendedor@sixxis.com"
VENDEDOR_SENHA="troque-esta-senha-vendedor"

# --- Envio em massa (campanhas) ---
# Link publico da loja, usado na variavel {link} dos modelos de mensagem.
NEXT_PUBLIC_LOJA_URL="https://sixxis.com.br"
# Intervalo (ms) entre envios da campanha (anti-bloqueio). Padrao 1500.
CAMPANHA_THROTTLE_MS="1500"
# Limite de destinatarios por campanha. Padrao 1000.
CAMPANHA_LIMITE="1000"

# Canal SMS (Twilio). Sem estas envs, o canal fica "nao configurado".
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM=""

# Canal Email (Resend). Sem estas envs, o canal fica "nao configurado".
RESEND_API_KEY=""
RESEND_FROM=""

# --- Midia (Cloudflare R2, S3-compativel) ---
# Sem estas envs, a midia do WhatsApp NAO e persistida (degrada: mantem a URL
# original/efemera da Evolution como fallback). Bucket publico via R2_PUBLIC_URL.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_URL="https://midia.exemplo.com"

# --- Retencao / limpeza ---
# Poda o payload bruto (raw) de mensagens mais antigas que N meses (default 6).
# 0 desativa. O conteudo/transcricao/midia/status sao preservados.
RETENCAO_RAW_MESES="6"
# Opcional (0 = desligado): arquiva conversas inativas ha mais de M meses.
ARQUIVAR_INATIVAS_MESES="0"

# Ambiente
NODE_ENV="development"
PORT="3000"
