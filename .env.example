# Banco de dados PostgreSQL (Prisma)
# Em dev local com Docker use a porta 5433 (ver README/instrucoes)
DATABASE_URL="postgresql://postgres:dev@localhost:5433/sixxiscrm"

# Redis (fila BullMQ). maxRetriesPerRequest e tratado no codigo.
REDIS_URL="redis://localhost:6379"

# Evolution API (recepcao de mensagens do WhatsApp)
EVOLUTION_BASE_URL="https://sua-evolution.exemplo.com"
EVOLUTION_API_KEY="troque-esta-chave"
EVOLUTION_INSTANCE="sixxis-wa1"

# Segredo compartilhado para validar o webhook da Evolution
WEBHOOK_SECRET="troque-este-segredo"

# Ambiente
NODE_ENV="development"
PORT="3000"
