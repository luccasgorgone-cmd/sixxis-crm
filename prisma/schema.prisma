// Prisma 7 — generator novo "prisma-client" (Rust-free) com saida em src/generated.
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Papel {
  VENDEDOR
  POS_VENDA
  COLABORADOR
  ADMIN
}

enum DirecaoMsg {
  IN
  OUT
}

enum TipoMsg {
  TEXTO
  AUDIO
  IMAGEM
  VIDEO
  DOCUMENTO
  OUTRO
}

enum StatusNeg {
  ABERTO
  GANHO
  PERDIDO
}

// Quem esta conduzindo o atendimento da conversa.
enum AtendidoPor {
  HUMANO
  IA
}

// Ciclo de vida do envio de uma mensagem outbound (OUT).
enum StatusEnvio {
  ENVIANDO
  ENVIADA
  ENTREGUE
  ERRO
}

// Temperatura do negocio (interesse/probabilidade de fechar).
enum Temperatura {
  QUENTE
  MORNO
  FRIO
}

// Tipo da etapa do funil: aberta (em andamento) ou fechamento ganho/perdido.
enum TipoEtapa {
  ABERTA
  GANHO
  PERDIDO
}

// Tipos de evento registrados na linha do tempo do negocio.
enum TipoHistorico {
  CRIACAO
  ETAPA
  NOTA
  ETIQUETA
  ATRIBUICAO
  VALOR
  GANHO
  PERDA
}

// Estrategia de distribuicao de leads entre vendedores.
enum EstrategiaRoteamento {
  ROUND_ROBIN
}

// Finalidade de um numero/conversa/negocio: pre-venda (VENDA) ou pos-venda.
enum Finalidade {
  VENDA
  POS_VENDA
}

// Finalidade de uma etapa do funil. AMBAS aparece nos dois funis.
enum FinalidadeEtapa {
  VENDA
  POS_VENDA
  AMBAS
}

// Metrica acompanhada por uma meta. As tres primeiras "maior e melhor"; os dois
// tempos "menor e melhor" (alvo = teto a nao ultrapassar).
enum MetricaMeta {
  VALOR_VENDIDO
  QTD_GANHOS
  CONVERSAO
  CLIENTES_ATENDIDOS
  TEMPO_RESPOSTA
  TEMPO_RESOLUCAO
}

// Escopo de uma meta: de um colaborador especifico ou da equipe inteira.
enum EscopoMeta {
  COLABORADOR
  EQUIPE
}

// Janela de apuracao da meta.
enum PeriodoMeta {
  DIARIA
  SEMANAL
  MENSAL
  CUSTOM
}

// Tipos de evento na linha do tempo do CLIENTE (nivel lead).
enum AtividadeTipo {
  CONTATO
  ATRIBUICAO
  TRANSFERENCIA
  ASSUMIDO
  NOTA
  ETIQUETA
  ETAPA
  VALOR
  GANHO
  PERDA
  CRIACAO
  EDICAO
  PENDENCIA
  LEMBRETE
  MENSAGEM_APAGADA
  // Acompanhamento pos-venda: nota fiscal, empresa faturada e garantia.
  ACOMPANHAMENTO
}

// Estado de um lembrete/agendamento de contato.
enum StatusLembrete {
  PENDENTE
  FEITO
  CANCELADO
}

// Estado de uma tarefa da agenda do agente.
enum StatusTarefa {
  PENDENTE
  CONCLUIDA
  CANCELADA
}

// Canal de um envio em massa.
enum CanalEnvio {
  WHATSAPP
  SMS
  EMAIL
}

// Ciclo de vida de uma campanha de envio em massa.
enum StatusCampanha {
  RASCUNHO
  ENVIANDO
  CONCLUIDA
  CANCELADA
}

// Estado do envio para um destinatario de campanha. (Distinto de StatusEnvio,
// que e o ciclo de uma Mensagem 1:1.)
enum StatusDestino {
  PENDENTE
  ENVIADO
  FALHA
  PULADO
}

model Agente {
  id          String     @id @default(cuid())
  nome        String
  email       String     @unique
  senha       String?
  papel         Papel    @default(COLABORADOR)
  telefone      String?
  avatarUrl     String?
  metaMensal    Decimal? @db.Decimal(12, 2)
  ativo         Boolean  @default(true)
  acessoVenda   Boolean  @default(true)
  acessoPosVenda Boolean @default(false)
  ultimoLogin   DateTime?
  negocios              Negocio[]
  notas                 Nota[]
  conversas             Conversa[]
  historicos            HistoricoNegocio[]
  leadsComoDono         Lead[]             @relation("LeadDono")
  leadsComoDonoPosVenda Lead[]             @relation("LeadDonoPosVenda")
  atividades            Atividade[]
  metas                 Meta[]             @relation("MetaAlvo")
  metasCriadas          Meta[]             @relation("MetaCriador")
  lembretes             Lembrete[]
  campanhas             Campanha[]
  notificacoes          Notificacao[]
  tarefas               Tarefa[]
  criadoEm              DateTime           @default(now())
}

model Lead {
  id            String         @id @default(cuid())
  nome          String?
  // Nome vindo do WhatsApp (pushName) e override manual editavel pelo atendente.
  // Nome efetivo na UI = nomeManual || pushName || nome || telefone (lib/cliente.ts).
  pushName      String?
  nomeManual    String?
  fotoUrl       String?
  fotoAtualizadaEm DateTime?
  telefone      String         @unique
  email         String?
  empresa       String?
  cpf           String?
  cnpj          String?
  // Data de nascimento (apenas a data; hora ignorada). Base para aniversarios.
  dataNascimento DateTime?
  anotacoes     String?        @db.Text
  origem        String?
  // Opt-out de comunicacoes em massa: false = nao incluir em campanhas.
  aceitaContato Boolean        @default(true)
  ctwaClid      String?
  // Origem por ANUNCIO (Click-to-WhatsApp): dados do referral do contextInfo da
  // Evolution, gravados na 1a mensagem (nunca sobrescritos com vazio depois).
  anuncioId      String?
  anuncioTitulo  String?
  anuncioUrl     String?
  origemDetalhe  String?
  clienteSiteId  String?
  // Acompanhamento pos-venda: nota fiscal (texto livre) e empresa que faturou.
  notaFiscal     String?
  // Garantia pos-venda: null = nao definido, true = com garantia, false = sem.
  garantia       Boolean?
  empresaFaturadaId String?
  empresaFaturada   EmpresaFaturada? @relation(fields: [empresaFaturadaId], references: [id], onDelete: SetNull)
  donoId         String?
  dono           Agente?        @relation("LeadDono", fields: [donoId], references: [id])
  donoPosVendaId String?
  donoPosVenda   Agente?        @relation("LeadDonoPosVenda", fields: [donoPosVendaId], references: [id])
  conversas      Conversa[]
  negocios       Negocio[]
  etiquetas      LeadEtiqueta[]
  notas          Nota[]
  atividades     Atividade[]
  lembretes      Lembrete[]
  campanhaDestinos CampanhaDestino[]
  orcamentos     Orcamento[]
  enderecos      Endereco[]
  tarefas        Tarefa[]
  produtosInteresse LeadProdutoInteresse[]
  criadoEm       DateTime       @default(now())

  @@index([donoId])
  @@index([donoPosVendaId])
  @@index([empresaFaturadaId])
}

// Endereco de um cliente. Varios por cliente; um pode ser marcado principal.
// Preenchimento assistido por CEP (ViaCEP) na UI, com fallback manual.
model Endereco {
  id          String   @id @default(cuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  apelido     String?
  cep         String?
  logradouro  String?
  numero      String?
  complemento String?
  bairro      String?
  cidade      String?
  uf          String?
  principal   Boolean  @default(false)
  criadoEm    DateTime @default(now())

  @@index([leadId])
}

// Produto pelo qual o cliente tem INTERESSE (distinto do produto comprado/
// orcamento). Lista gerenciavel no admin. Varios por cliente via LeadProdutoInteresse.
model ProdutoInteresse {
  id       String   @id @default(cuid())
  nome     String   @unique
  ativo    Boolean  @default(true)
  ordem    Int      @default(0)
  leads    LeadProdutoInteresse[]
  criadoEm DateTime @default(now())
}

// Vinculo N:N cliente <-> produto de interesse (varios por cliente).
model LeadProdutoInteresse {
  id                 String           @id @default(cuid())
  leadId             String
  lead               Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  produtoInteresseId String
  produtoInteresse   ProdutoInteresse @relation(fields: [produtoInteresseId], references: [id])
  criadoEm           DateTime         @default(now())

  @@unique([leadId, produtoInteresseId])
  @@index([produtoInteresseId])
}

// Empresa que emite a nota fiscal (faturamento). Lista gerenciavel no admin.
model EmpresaFaturada {
  id       String   @id @default(cuid())
  nome     String   @unique
  ativo    Boolean  @default(true)
  ordem    Int      @default(0)
  leads    Lead[]
  criadoEm DateTime @default(now())
}

model Conversa {
  id               String            @id @default(cuid())
  leadId           String
  lead             Lead              @relation(fields: [leadId], references: [id])
  agenteId         String?
  agente           Agente?           @relation(fields: [agenteId], references: [id])
  instancia        String            @default("sixxis-wa1")
  instanciaId      String?
  instanciaRef     InstanciaWhatsApp? @relation(fields: [instanciaId], references: [id])
  finalidade       Finalidade        @default(VENDA)
  status           String            @default("aberta")
  atendidoPor      AtendidoPor       @default(HUMANO)
  naoLidas         Int               @default(0)
  ultimaMensagemEm DateTime?
  arquivada        Boolean           @default(false)
  // Ultima vez que enviamos a mensagem automatica de "fora do horario" nesta
  // conversa (evita repetir a cada mensagem; reenvia apos ~8h).
  foraHorarioAvisadoEm DateTime?
  mensagens        Mensagem[]
  criadoEm         DateTime          @default(now())

  // No MAXIMO uma conversa ATIVA por (cliente, setor): todos os numeros do
  // mesmo setor caem nela; venda e pos-venda seguem como threads separadas.
  // No banco a unicidade e PARCIAL (WHERE arquivada = false) para preservar
  // o historico de conversas antigas arquivadas (nunca deletadas) — ver a
  // migracao fatia231a. O @@unique aqui documenta a regra e gera o tipo.
  @@unique([leadId, finalidade])
  @@index([leadId])
  @@index([agenteId])
  @@index([instanciaId])
  @@index([finalidade])
  @@index([agenteId, ultimaMensagemEm])
}

model Mensagem {
  id          String     @id @default(cuid())
  externalId  String     @unique
  conversaId  String
  conversa    Conversa   @relation(fields: [conversaId], references: [id])
  direcao     DirecaoMsg
  tipo        TipoMsg      @default(TEXTO)
  conteudo    String?      @db.Text
  transcricao String?      @db.Text
  mediaUrl    String?
  // Numero (instancia Evolution) que originou/enviou esta mensagem. Permite
  // mostrar na thread por qual numero cada mensagem entrou/saiu mesmo na
  // conversa unificada (varios numeros do mesmo setor caem na mesma conversa).
  instancia   String?
  instanciaId String?
  lida        Boolean      @default(false)
  statusEnvio StatusEnvio?
  // Apagamento (revoke). O conteudo NUNCA e removido — so marcado. apagadaPor:
  // "COLABORADOR" (revogou para o cliente) | "CLIENTE" (cliente apagou).
  apagada     Boolean      @default(false)
  apagadaEm   DateTime?
  apagadaPor  String?
  apagadaPorId String?
  // Payload bruto da Evolution. Podado (NULL) apos RETENCAO_RAW_MESES; o conteudo
  // util (conteudo/transcricao/tipo/midia/status) e preservado fora do raw.
  raw         Json?
  hora        DateTime     @default(now())

  @@index([conversaId, hora])
  @@index([conversaId, direcao])
}

model Etapa {
  id         String          @id @default(cuid())
  nome       String
  ordem      Int
  cor        String          @default("#3cbfb3")
  tipo       TipoEtapa       @default(ABERTA)
  finalidade FinalidadeEtapa @default(VENDA)
  ativo      Boolean         @default(true)
  negocios   Negocio[]
  configsAlertaSla ConfigAlertaSla[]
}

// Configuracao de alerta de SLA por (finalidade, etapa): tempo maximo na etapa
// antes de alertar o dono. Separada por Venda e Pos-venda. SEPARADA do sistema
// de alertas ANTECIPADOS da agenda (lib/alertas.ts), que nao e tocado.
model ConfigAlertaSla {
  id               String         @id @default(cuid())
  finalidade       Finalidade
  etapaId          String
  etapa            Etapa          @relation(fields: [etapaId], references: [id], onDelete: Cascade)
  minutosParaAlerta Int
  ativo            Boolean        @default(true)
  som              String?
  alertas          AlertaNegocio[]
  criadoEm         DateTime       @default(now())

  @@unique([finalidade, etapaId])
}

// Alerta de SLA ATIVO de um negocio (resolvidoEm null = aberto). Fechado ao
// mover de etapa / ganho / perdido / resolver.
model AlertaNegocio {
  id          String          @id @default(cuid())
  negocioId   String
  negocio     Negocio         @relation(fields: [negocioId], references: [id], onDelete: Cascade)
  configId    String
  config      ConfigAlertaSla @relation(fields: [configId], references: [id], onDelete: Cascade)
  criadoEm    DateTime        @default(now())
  resolvidoEm DateTime?

  @@index([negocioId, resolvidoEm])
}

model Etiqueta {
  id    String         @id @default(cuid())
  nome  String
  cor   String         @default("#3cbfb3")
  // null = serve as duas finalidades (Ambas); senao restringe ao funil indicado.
  finalidade Finalidade?
  leads LeadEtiqueta[]

  @@index([finalidade])
}

model LeadEtiqueta {
  leadId     String
  etiquetaId String
  lead       Lead     @relation(fields: [leadId], references: [id])
  etiqueta   Etiqueta @relation(fields: [etiquetaId], references: [id])

  @@id([leadId, etiquetaId])
}

model Negocio {
  id            String             @id @default(cuid())
  leadId        String
  lead          Lead               @relation(fields: [leadId], references: [id])
  agenteId      String?
  agente        Agente?            @relation(fields: [agenteId], references: [id])
  etapaId       String?
  etapa         Etapa?             @relation(fields: [etapaId], references: [id])
  valor         Decimal?           @db.Decimal(12, 2)
  produtos      Json?
  status        StatusNeg          @default(ABERTO)
  temperatura   Temperatura        @default(MORNO)
  finalidade    Finalidade         @default(VENDA)
  // Pendencia operacional: negocio travado aguardando algo (orcamento, peca,
  // pagamento...). motivoPendencia descreve o porque para a carteira/tooltip.
  pendente        Boolean          @default(false)
  motivoPendencia String?          @db.Text
  // motivoPerda guarda o CODE (ver lib/motivosPerda); obs e a observacao livre.
  motivoPerda   String?
  motivoPerdaObs String?           @db.Text
  entrouEtapaEm DateTime           @default(now())
  fechadoEm     DateTime?
  historicos    HistoricoNegocio[]
  atividades    Atividade[]
  lembretes     Lembrete[]
  orcamentos    Orcamento[]
  alertasSla    AlertaNegocio[]
  criadoEm      DateTime           @default(now())
  atualizadoEm  DateTime           @updatedAt

  @@index([etapaId, status])
  @@index([agenteId])
  @@index([finalidade])
  @@index([agenteId, status, fechadoEm])
}

// Linha do tempo do negocio: cada mudanca relevante vira um registro.
model HistoricoNegocio {
  id        String        @id @default(cuid())
  negocioId String
  negocio   Negocio       @relation(fields: [negocioId], references: [id])
  agenteId  String?
  agente    Agente?       @relation(fields: [agenteId], references: [id])
  tipo      TipoHistorico
  descricao String        @db.Text
  criadoEm  DateTime      @default(now())

  @@index([negocioId, criadoEm])
}

model Nota {
  id       String   @id @default(cuid())
  leadId   String
  lead     Lead     @relation(fields: [leadId], references: [id])
  agenteId String?
  agente   Agente?  @relation(fields: [agenteId], references: [id])
  texto    String   @db.Text
  criadoEm DateTime @default(now())
}

// Observacao pre-definida aplicavel em 1 clique no painel do cliente/negocio.
model ObservacaoPreset {
  id       String   @id @default(cuid())
  texto    String   @db.Text
  ordem    Int      @default(0)
  ativo    Boolean  @default(true)
  criadoEm DateTime @default(now())
}

// Configuracao (singleton) do roteamento de leads entre vendedores.
model ConfigRoteamento {
  id                String               @id @default(cuid())
  estrategia        EstrategiaRoteamento @default(ROUND_ROBIN)
  ativo             Boolean              @default(true)
  respeitarDono     Boolean              @default(true)
  ponteiroAgenteId  String?
  ponteiroPosVendaId String?
  atualizadoEm      DateTime             @updatedAt
}

// Numero de WhatsApp (instancia Evolution) com finalidade VENDA ou POS_VENDA.
model InstanciaWhatsApp {
  id                 String     @id @default(cuid())
  nome               String
  instanciaEvolution String     @unique
  numero             String?
  finalidade         Finalidade @default(VENDA)
  ativo              Boolean    @default(true)
  statusConexao      String?
  conversas          Conversa[]
  criadoEm           DateTime   @default(now())
  atualizadoEm       DateTime   @updatedAt
}

// Linha do tempo do CLIENTE (nivel lead): contato, atribuicao, transferencia,
// notas, etiquetas, eventos do negocio etc.
model Atividade {
  id        String        @id @default(cuid())
  leadId    String
  lead      Lead          @relation(fields: [leadId], references: [id])
  negocioId String?
  negocio   Negocio?      @relation(fields: [negocioId], references: [id])
  agenteId  String?
  agente    Agente?       @relation(fields: [agenteId], references: [id])
  tipo      AtividadeTipo
  descricao String        @db.Text
  criadoEm  DateTime      @default(now())

  @@index([leadId, criadoEm])
}

// Modelo de mensagem (antiga "Resposta rapida") usavel no compositor do inbox e
// como base de campanhas. categoria organiza o catalogo; finalidade null = ambas.
model RespostaRapida {
  id           String      @id @default(cuid())
  titulo       String
  atalho       String?
  texto        String      @db.Text
  // atalho | aniversario | cupom | data_comemorativa | desconto_relampago |
  // retomada | geral | boas_vindas | agradecimento | avaliacao | follow_up
  categoria    String      @default("atalho")
  // Autor da resposta rapida: null = de SISTEMA (global, gerida pelo admin);
  // preenchido = pessoal do atendente (so ele edita/exclui/reordena as dele).
  criadoPorId  String?
  finalidade   Finalidade?
  // Redacoes alternativas da MESMA intencao (texto e a principal). aplicarModelo
  // sorteia uma entre [texto, ...variacoes] por destinatario.
  variacoes    String[]    @default([])
  ativo        Boolean     @default(true)
  ordem        Int         @default(0)
  criadoEm     DateTime    @default(now())
  atualizadoEm DateTime    @updatedAt

  @@index([categoria])
  @@index([criadoPorId])
}

// Lembrete/agendamento de contato com um cliente.
model Lembrete {
  id          String         @id @default(cuid())
  leadId      String
  lead        Lead           @relation(fields: [leadId], references: [id])
  negocioId   String?
  negocio     Negocio?       @relation(fields: [negocioId], references: [id])
  agenteId    String
  agente      Agente         @relation(fields: [agenteId], references: [id])
  finalidade  Finalidade
  dataHora    DateTime
  nota        String?        @db.Text
  status      StatusLembrete @default(PENDENTE)
  // Alerta antecipado: minutos antes de dataHora p/ notificar; notificadoEm
  // marca que a notificacao ja foi gerada (evita duplicar).
  lembrarAntesMin Int?
  notificadoEm    DateTime?
  criadoEm    DateTime       @default(now())
  concluidoEm DateTime?

  @@index([agenteId, status, dataHora])
  @@index([leadId])
}

// Tarefa/compromisso da agenda do agente. Pode ou nao estar ligada a um cliente.
// Alerta antecipado igual ao do lembrete (lembrarAntesMin + notificadoEm).
model Tarefa {
  id              String       @id @default(cuid())
  agenteId        String
  agente          Agente       @relation(fields: [agenteId], references: [id])
  titulo          String
  descricao       String?      @db.Text
  dataHora        DateTime
  duracaoMin      Int?
  leadId          String?
  lead            Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)
  lembrarAntesMin Int?
  notificadoEm    DateTime?
  status          StatusTarefa @default(PENDENTE)
  criadoEm        DateTime     @default(now())

  @@index([agenteId, dataHora])
  @@index([leadId])
}

// Notificacao do agente (centro de notificacoes do sino). tipo livre:
// ANIVERSARIO | LEMBRETE | TAREFA | GERAL... link aponta para cliente/agenda.
model Notificacao {
  id        String   @id @default(cuid())
  agenteId  String
  agente    Agente   @relation(fields: [agenteId], references: [id])
  tipo      String
  titulo    String
  descricao String?  @db.Text
  link      String?
  lida      Boolean  @default(false)
  leadId    String?
  criadoEm  DateTime @default(now())

  @@index([agenteId, lida, criadoEm])
}

// Orcamento de um cliente. Multiplos por cliente ficam todos armazenados
// (historico). voltagem e opcional ("110V"/"220V"/"Bivolt"...).
model Orcamento {
  id           String   @id @default(cuid())
  leadId       String
  lead         Lead     @relation(fields: [leadId], references: [id])
  negocioId    String?
  negocio      Negocio? @relation(fields: [negocioId], references: [id])
  produto      String
  valor        Decimal? @db.Decimal(12, 2)
  voltagem     String?
  observacao   String?  @db.Text
  criadoPorId  String?
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@index([leadId])
}

// Campanha de envio em massa (multicanal). filtroJson guarda o recorte usado;
// valoresJson guarda as variaveis digitadas (cupom, desconto...).
model Campanha {
  id          String            @id @default(cuid())
  agenteId    String
  agente      Agente            @relation(fields: [agenteId], references: [id])
  finalidade  Finalidade
  canal       CanalEnvio
  modeloId    String?
  assunto     String?
  mensagem    String            @db.Text
  valoresJson Json?
  // Redacoes alternativas do modelo (copiadas na criacao) para o worker sortear
  // por destinatario sem depender do modelo original (que pode mudar).
  variacoesJson Json?
  filtroJson  Json
  total       Int
  enviados    Int               @default(0)
  falhas      Int               @default(0)
  pulados     Int               @default(0)
  status      StatusCampanha    @default(RASCUNHO)
  criadoEm    DateTime          @default(now())
  iniciadoEm  DateTime?
  concluidoEm DateTime?
  destinos    CampanhaDestino[]

  @@index([agenteId, criadoEm])
  @@index([status])
}

// Destinatario resolvido de uma campanha, com status/erro por envio.
model CampanhaDestino {
  id         String        @id @default(cuid())
  campanhaId String
  campanha   Campanha      @relation(fields: [campanhaId], references: [id])
  leadId     String
  lead       Lead          @relation(fields: [leadId], references: [id])
  destino    String
  // Texto renderizado (modelo + variaveis) realmente enviado a este destino.
  mensagem   String?       @db.Text
  status     StatusDestino @default(PENDENTE)
  erro       String?
  enviadoEm  DateTime?

  @@index([campanhaId, status])
  @@index([leadId])
}

// Configuracao geral do CRM (singleton). horarios = JSON por dia da semana.
model ConfiguracaoCRM {
  id                 String   @id @default(cuid())
  nomeEmpresa        String?
  fuso               String   @default("America/Sao_Paulo")
  horarios           Json?
  mensagemForaHorario String?
  // Logo da empresa guardada no proprio banco (sem storage externo).
  // logoData = data URL (base64) ou SVG sanitizado; logoEm versiona o cache.
  logoData           String?   @db.Text
  logoMime           String?
  logoEm             DateTime?
  // Meta Conversions API (server-side). Token guardado aqui (nunca exposto ao
  // browser). testEventCode usa o modo de teste do Gerenciador de Eventos.
  metaPixelId        String?
  metaCapiToken      String?
  metaTestEventCode  String?
  atualizadoEm       DateTime @updatedAt
}

// Meta de desempenho. agenteId null = meta de EQUIPE (toda a equipe); preenchido
// = meta de um COLABORADOR. finalidade AMBAS = sem recorte de funil.
model Meta {
  id           String          @id @default(cuid())
  nome         String?
  escopo       EscopoMeta
  agenteId     String?
  agente       Agente?         @relation("MetaAlvo", fields: [agenteId], references: [id])
  // Quem criou a meta. null = tratada como criada pela administracao. Trava a
  // edicao: colaborador so edita as proprias (criadoPorId = ele mesmo).
  criadoPorId  String?
  criadoPor    Agente?         @relation("MetaCriador", fields: [criadoPorId], references: [id])
  finalidade   FinalidadeEtapa @default(AMBAS)
  metrica      MetricaMeta
  alvo         Float
  periodo      PeriodoMeta
  inicio       DateTime
  fim          DateTime
  ativo        Boolean         @default(true)
  criadoEm     DateTime        @default(now())
  atualizadoEm DateTime        @updatedAt

  @@index([agenteId, ativo])
}

// Configuracao do Agente IA (singleton). Apenas config nesta fase (sem inferencia).
model ConfigAgenteIA {
  id                  String   @id @default(cuid())
  ativo               Boolean  @default(false)
  modelo              String   @default("claude-haiku-4-5")
  promptSistema       String?  @db.Text
  responderForaHorario Boolean @default(false)
  responderLeadNovo   Boolean  @default(false)
  handoffPalavras     String?
  // Horario de operacao da IA.
  opera24h             Boolean @default(true)
  usarHorarioComercial Boolean @default(false)
  horarios             Json?
  // Comportamento.
  saudacaoAutomatica       String? @db.Text
  segundosAntesDeResponder Int?
  // Handoff (passar para humano).
  maxMensagensAntesHandoff Int?
  mensagemHandoff          String? @db.Text
  handoffSeClientePedir    Boolean @default(true)
  handoffSeLeadQuente      Boolean @default(false)
  atualizadoEm        DateTime @updatedAt
}
